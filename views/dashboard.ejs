<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>FleetTrack Dashboard</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: sans-serif;
    }

    body {
      background: #f3f4f6;
    }

    .sidebar {
      width: 260px;
      height: 100vh;
      background: #111827;
      position: fixed;
      left: 0;
      top: 0;
      padding: 20px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      z-index: 1000;
    }

    .logo {
      color: white;
      margin-bottom: 30px;
    }

    .sidebar a {
      color: #d1d5db;
      text-decoration: none;
      display: block;
      padding: 14px;
      border-radius: 10px;
      margin-bottom: 10px;
      transition: 0.3s;
    }

    .sidebar a:hover {
      background: #1f2937;
      color: white;
    }

    .logout {
      background: #dc2626;
      color: white !important;
    }

    /* ===================== */
    /* MAIN */
    /* ===================== */

    .main {
      margin-left: 260px;
      padding: 25px;
    }

    /* ===================== */
    /* TOPBAR */
    /* ===================== */

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .menu-btn {
      border: none;
      background: none;
      font-size: 30px;
      display: none;
    }

    .top-right {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .notification {
      font-size: 22px;
      cursor: pointer;
    }

    .profile {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .avatar {
      width: 45px;
      height: 45px;
      border-radius: 50%;
      background: #2563eb;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
    }

    /* ===================== */
    /* STATS */
    /* ===================== */

    .stats-card {
      padding: 25px;
      border-radius: 20px;
      color: white;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
    }

    .stats-card h2 {
      font-size: 35px;
    }

    .blue {
      background: #2563eb;
    }

    .yellow {
      background: #f59e0b;
    }

    .red {
      background: #ef4444;
    }

    .green {
      background: #22c55e;
    }


    .search-box input {
      width: 100%;
      padding: 15px;
      border: none;
      border-radius: 15px;
      outline: none;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
      margin-bottom: 30px;
    }



    .truck-card-ui {
      background: white;
      border-radius: 20px;
      padding: 20px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
      transition: 0.3s;
    }

    .truck-card-ui:hover {
      transform: translateY(-5px);
    }

    .truck-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
    }

    .truck-actions {
      display: flex;
      justify-content: space-between;
      margin-top: 20px;
    }



    @media(max-width:992px) {

      .sidebar {
        left: -260px;
        transition: 0.3s;
      }

      .sidebar.show {
        left: 0;
      }

      .main {
        margin-left: 0;
      }

      .menu-btn {
        display: block;
      }
    }
  </style>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- Chart JS -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body>

  <!-- ===================== -->
  <!-- SIDEBAR -->
  <!-- ===================== -->

  <div class="sidebar" id="sidebar">

    <div>
      <h3 class="logo">🚛 FleetTrack</h3>

      <a href="/dashboard">
        <i class="bi bi-grid"></i> Dashboard
      </a>

      <a href="/add">
        <i class="bi bi-plus-circle"></i> Add Truck
      </a>

      <a href="/profile">
        <i class="bi bi-person"></i> Profile
      </a>
    </div>

    <a href="/logout" class="logout">
      <i class="bi bi-box-arrow-right"></i> Logout
    </a>

  </div>

  <div class="main">

    <div class="topbar">

      <button class="menu-btn" onclick="toggleSidebar()">
        <i class="bi bi-list"></i>
      </button>

      <div class="top-right">

        <div class="notification">
          <i class="bi bi-bell-fill"></i>
        </div>

        <div class="profile">
          <div class="avatar">
            <%= user.username ? user.username.charAt(0).toUpperCase() : "U" %>
          </div>

          <div>
            <h6 class="mb-0">
              <%= user.username %>
            </h6>
            <small>
              <%= user.email %>
            </small>
          </div>
        </div>

      </div>

    </div>

    <!-- ===================== -->
    <!-- STATS -->
    <!-- ===================== -->

    <div class="row g-4 mt-1">

      <div class="col-md-3">
        <div class="stats-card blue">
          <h2>
            <%= trucks.length %>
          </h2>
          <p>Total Trucks</p>
        </div>
      </div>

      <div class="col-md-3">
        <div class="stats-card yellow">
          <h2 id="expiringCount">
            <%=soon%>
          </h2>
          <p>Expiring Soon</p>
        </div>
      </div>

      <div class="col-md-3">
        <div class="stats-card red">
          <h2 id="expiredCount">
            <%=ex%>
          </h2>
          <p>Expired</p>
        </div>
      </div>

      <div class="col-md-3">
        <div class="stats-card green">
          <h2 id="validCount">
            <%=v%>
          </h2>
          <p>Valid</p>
        </div>
      </div>

    </div>

    <div class="search-box mt-4">
      <input type="text" id="search" placeholder="Search trucks..." onkeyup="searchTruck()">
    </div>



    <div class="row">

      <% let valid=0; let expired=0; let expiring=0; trucks.forEach(truck=> {

        let diff = Math.ceil(
        (new Date(truck.insurance) - new Date())
        / (1000 * 60 * 60 * 24)
        );

        let status = "";
        let badge = "";

        if(diff < 0){ status="Expired" ; badge="danger" ; expired++; } else if(diff <=4){ status="Expiring Soon" ;
          badge="warning" ; expiring++; } else{ status="Valid" ; badge="success" ; valid++; } %>

          <div class="col-lg-4 col-md-6 mb-4 truck-card">

            <div class="truck-card-ui">

              <div class="truck-top">

                <h4>
                  <%= truck.truckNo %>
                </h4>

                <span class="badge bg-<%= badge %>">
                  <%= status %>
                </span>

              </div>

              <div class="truck-body">

                <p>
                  <strong>Owner:</strong>
                  <%= truck.owner %>
                </p>

                <p>
                  <strong>Mobile:</strong>
                  <%= truck.mobile %>
                </p>

                <p>
                  <strong>Insurance:</strong>
                  <%= truck.insurance ? new Date(truck.insurance).toDateString() : "" %>
                </p>

              </div>

              <div class="truck-actions">

                <a href="/edit/<%= truck._id %>" class="btn btn-warning btn-sm">
                  Edit
                </a>

                <form action="/delete/<%= truck._id %>" method="POST">

                  <button class="btn btn-danger btn-sm">
                    Delete
                  </button>

                </form>

              </div>

            </div>

          </div>

          <% }) %>

    </div>

  </div>



  <script>

    // SEARCH

    function searchTruck() {

      let input =
        document.getElementById("search")
          .value.toLowerCase();

      let cards =
        document.querySelectorAll(".truck-card");

      cards.forEach(card => {

        let text =
          card.innerText.toLowerCase();

        card.style.display =
          text.includes(input)
            ? "block"
            : "none";
      });
    }



    function toggleSidebar() {
      document.getElementById("sidebar")
        .classList.toggle("show");
    }


  </script>

</body>

</html>