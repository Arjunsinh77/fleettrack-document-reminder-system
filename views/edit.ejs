<!DOCTYPE html>
<html>
<head>
  <title>Edit Truck</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-primary px-3">
  <h4 class="text-white">Edit Truck</h4>
  <a href="/dashboard" class="btn btn-light">Back</a>
</nav>

<div class="container mt-4">

<div class="card p-4 shadow">

  <form method="POST" action="/edit/<%= truck._id %>">

    <input name="truckNo" value="<%= truck.truckNo %>" class="form-control mb-2">

    <input name="owner" value="<%= truck.owner %>" class="form-control mb-2">

    <input name="mobile" value="<%= truck.mobile %>" class="form-control mb-2">

    <label>Insurance Expiry</label>
    <input type="date" name="insurance"
      value="<%= truck.insurance ? truck.insurance.toISOString().split('T')[0] : '' %>"
      class="form-control mb-3">

    <button class="btn btn-success w-100">Update</button>

  </form>

</div>

</div>

</body>
</html>