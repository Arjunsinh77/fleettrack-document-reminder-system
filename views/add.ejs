<!DOCTYPE html>
<html>
<head>
  <title>Add Truck</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-primary px-3">
  <h4 class="text-white">Add Truck</h4>
  <a href="/dashboard" class="btn btn-light">Back</a>
</nav>

<div class="container mt-4">

<div class="card p-4 shadow">

  <form method="POST" action="/add">

    <input name="truckNo" class="form-control mb-2" placeholder="Truck Number">
    <input name="owner" class="form-control mb-2" placeholder="Owner Name">
    <input name="mobile" class="form-control mb-2" placeholder="Mobile">

    <label>Insurance Expiry</label>
    <input type="date" name="insurance" class="form-control mb-3">

    <button class="btn btn-success w-100">Save Truck</button>

  </form>

</div>

</div>

</body>
</html>