<!DOCTYPE html>
<html>
<head>
  <title>Profile</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    img{
         width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 12px;
    }
  </style>
</head>

<body class="bg-light">

<!-- Navbar -->
<nav class="navbar navbar-dark bg-primary px-3">
  <a class="navbar-brand" href="/">🚛 Truck Manager</a>
  <a href="/dashboard" class="btn btn-light">Back</a>
</nav>

<div class="container mt-5">

  <div class="card shadow p-4 text-center" style="max-width: 400px; margin:auto;">

    <!-- Avatar (First Letter) -->
    <div class="avatar mb-3">
     <img src="/img/uploads/<%=user.profilepic%>" alt="img">
    </div>
    <a href="/upload" class="btn btn-primary w-100" style="max-width: 200px; margin-left:23%; margin-bottom: 20px;">upload image</a>

    <!-- User Info -->
    <h4><%= user ? user.username : "User Name" %></h4>
    <p class="text-muted"><%= user ? user.email : "email@example.com" %></p>
    <p><strong>Mobile:</strong> <%= user ? user.mobile : "-" %></p>

    <hr>

    <!--<a href="#" class="btn btn-primary w-100">Edit Profile</a> Edit Button (optional) -->

  </div>

</div>

</body>
</html>